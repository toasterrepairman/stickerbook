{
  "app-id": "com.github.toasterrepair.Stickerbook",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.node20"
  ],
  "command": "stickerbook",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=network",
    "--filesystem=home",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.kde.StatusNotifierWatcher"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/node20/bin",
    "env": {
      "CARGO_HOME": "/run/build/stickerbook/cargo",
      "npm_config_nodedir": "/usr/lib/sdk/node20"
    }
  },
  "modules": [
    {
      "name": "stickerbook",
      "buildsystem": "simple",
      "build-commands": [
        "tar xzf vendor.tar.gz",
        "mkdir -p .cargo",
        "printf '[source.crates-io]\\nreplace-with = \"vendored-sources\"\\n\\n[source.vendored-sources]\\ndirectory = \"vendor\"' > .cargo/config.toml",
        "cargo build --release --locked",
        "install -Dm755 target/release/stickerbook /app/bin/stickerbook",
        "install -Dm644 resources/com.github.toasterrepair.Stickerbook.desktop /app/share/applications/com.github.toasterrepair.Stickerbook.desktop",
        "install -Dm644 resources/com.github.toasterrepair.Stickerbook.png /app/share/icons/hicolor/256x256/apps/com.github.toasterrepair.Stickerbook.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        },
        {
          "type": "file",
          "path": "vendor.tar.gz"
        }
      ]
    }
  ]
}
